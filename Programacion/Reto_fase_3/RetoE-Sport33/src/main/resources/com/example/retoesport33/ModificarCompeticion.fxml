<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controllers.Competicion.MoCompeticionController">
    <children>
        <Label layoutX="175.0" layoutY="35.0" text="MODIFICAR COMPETICIÓN">
            <font>
                <Font name="System Bold" size="20.0" />
            </font>
        </Label>

        <VBox layoutX="100.0" layoutY="90.0" spacing="15.0">
            <children>
                <HBox spacing="10.0" alignment="CENTER_LEFT">
                    <children>
                        <Label text="Código:" prefWidth="80.0" />
                        <TextField fx:id="tfCodigo" promptText="Ingrese código" />
                        <Button fx:id="BtnBuscar" mnemonicParsing="Parsing" onAction="#onBuscar" text="Buscar" style="-fx-background-color: #d6cfda; -fx-text-fill: white;" />
                    </children>
                </HBox>

                <HBox spacing="10.0" alignment="CENTER_LEFT">
                    <children>
                        <Label text="Nombre:" prefWidth="80.0" />
                        <TextField fx:id="tfNombre" prefWidth="225.0" />
                    </children>
                </HBox>

                <HBox spacing="10.0" alignment="CENTER_LEFT">
                    <children>
                        <Label text="Estado:" prefWidth="80.0" />
                        <ComboBox fx:id="cbEstado" prefWidth="225.0" />
                    </children>
                </HBox>

                <HBox spacing="10.0" alignment="CENTER_LEFT">
                    <children>
                        <Label text="Premio:" prefWidth="80.0" />
                        <TextField fx:id="tfPremio" prefWidth="225.0" />
                    </children>
                </HBox>
            </children>
        </VBox>

        <HBox layoutX="180.0" layoutY="320.0" spacing="50.0">
            <children>
                <Button fx:id="BtnActualizar" mnemonicParsing="false" onAction="#onActualizar" text="Actualizar" prefWidth="100.0" style="-fx-background-color: #d6cfda; -fx-text-fill: white;" />
                <Button fx:id="BtnVolver" mnemonicParsing="false" onAction="#onVolver" text="Volver" prefWidth="100.0" />
            </children>
        </HBox>
    </children>
</AnchorPane>
