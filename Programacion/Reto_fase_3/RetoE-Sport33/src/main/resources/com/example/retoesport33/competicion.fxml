<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="300.0" prefWidth="400.0" spacing="12" style="-fx-padding: 20;"
      xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/25"
      fx:controller="Controllers.CompeticionVistaController">

    <Label style="-fx-font-size: 15; -fx-font-weight: bold;" text="DATOS DE LA COMPETICIÓN"/>

    <GridPane hgap="12" vgap="10">
        <columnConstraints>
            <ColumnConstraints percentWidth="50"/>
            <ColumnConstraints percentWidth="50"/>
        </columnConstraints>

        <Label text="Nombre" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <TextField fx:id="tfNombre" GridPane.columnIndex="0" GridPane.rowIndex="1"/>

        <Label text="Premio" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
        <TextField fx:id="tfPremio" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

        <Label text="Estado" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <ComboBox fx:id="cbEstado" maxWidth="Infinity"
                  GridPane.columnIndex="0" GridPane.rowIndex="3"/>
    </GridPane>

    <GridPane hgap="10">
        <columnConstraints>
            <ColumnConstraints percentWidth="25"/>
            <ColumnConstraints percentWidth="25"/>
            <ColumnConstraints percentWidth="25"/>
            <ColumnConstraints percentWidth="25"/>
        </columnConstraints>
        <Button fx:id="btnAlta"      text="Alta"      onAction="#onAlta"
                maxWidth="Infinity" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <Button fx:id="btnModificar" text="Modificar" onAction="#onModificar"
                maxWidth="Infinity" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
        <Button fx:id="btnVolver"    text="Volver"    onAction="#onVolver"
                maxWidth="Infinity" GridPane.columnIndex="3" GridPane.rowIndex="0"/>
    </GridPane>

</VBox>
